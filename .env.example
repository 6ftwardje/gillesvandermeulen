# Cloudflare Images
NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_ID=
NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_ACCOUNT_ID=
NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net
CLOUDFLARE_IMAGES_API_TOKEN=

# Mux hero background video
# Use a public Playback ID from a Mux Asset.
# Recommended for background video: upload as Basic quality.
NEXT_PUBLIC_MUX_HERO_PLAYBACK_ID=
# Optional: direct MP4 URL, useful as a mobile-browser fallback if Mux static renditions are enabled.
NEXT_PUBLIC_MUX_HERO_MP4_URL=
NEXT_PUBLIC_MUX_HERO_POSTER_TIME=0
NEXT_PUBLIC_MUX_HERO_MAX_RESOLUTION=720p
